{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the user."
        },
        "displayName": {
          "type": "string",
          "description": "The display name of the user."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the user's profile picture."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The role of the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the user was created."
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A user's favorite configuration template.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who favorited the template."
        },
        "templateId": {
          "type": "string",
          "description": "The ID of the favorited template."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the favorite was added."
        }
      },
      "required": ["userId", "templateId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/favorites/{favoriteId}": {
      "schema": {
        "$ref": "#/entities/Favorite"
      },
      "description": "Stores user favorite templates."
    }
  }
}
